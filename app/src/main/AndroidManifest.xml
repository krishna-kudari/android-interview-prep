<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name=".pulsenews.PulseNewsApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="PulseNews"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Interview">
        <activity
            android:name=".pulsenews.MainActivity"
            android:exported="true"
            android:label="@string/title_activity_main"
            android:theme="@style/Theme.Interview">
            <!--            <intent-filter>-->
            <!--                <action android:name="android.intent.action.MAIN" />-->
            <!--                <category android:name="android.intent.category.LAUNCHER" />-->
            <!--            </intent-filter>-->

            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="article"
                    android:scheme="pulsenews" />
            </intent-filter>

        </activity>

        <activity
            android:name=".coinwatch.MainActivity"
            android:theme="@style/Theme.Interview">

        </activity>
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".LifecycleLabActivity"
            android:exported="false" />
        <activity
            android:name=".SecondLifecycleActivity"
            android:exported="false" />
        <activity
            android:name=".recyclerlab.RecyclerViewLabActivity"
            android:exported="false" />
        <activity
            android:name=".compose.ComposeLabActivity"
            android:exported="false" />
        <activity
            android:name=".datastorelab.DataStoreLabActivity"
            android:exported="false" />
    </application>

</manifest>